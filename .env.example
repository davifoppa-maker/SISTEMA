# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Olist Tiny (API V3 OAuth2 / OpenID Connect)
# Obrigatórios para conectar: registre um aplicativo no portal de desenvolvedores
# do Tiny e cole o client_id/secret. O redirect_uri deve apontar para
# <APP_URL>/api/auth/tiny/callback e ser idêntico ao cadastrado no Tiny.
TINY_CLIENT_ID=
TINY_CLIENT_SECRET=
TINY_REDIRECT_URI=
# Endpoints (já têm defaults; sobrescreva só se a Olist mudar host/caminho)
TINY_API_BASE_URL=https://api.tiny.com.br/public-api/v3
TINY_AUTH_URL=https://accounts.tiny.com.br/realms/tiny/protocol/openid-connect/auth
TINY_TOKEN_URL=https://accounts.tiny.com.br/realms/tiny/protocol/openid-connect/token
TINY_SCOPE=openid offline_access
TINY_ORDERS_PATH=/pedidos
# Tokens estáticos (opcional, só p/ dev local; em produção o OAuth grava no Supabase)
TINY_ACCESS_TOKEN=
TINY_REFRESH_TOKEN=
TINY_WEBHOOK_SECRET=

# WhatsApp Web (worker Baileys no Railway) — caminho recomendado
WHATSAPP_WORKER_URL=
WHATSAPP_WORKER_TOKEN=

# Meta WhatsApp Cloud API (alternativa oficial; usada só se o worker não estiver setado)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERIFY_TOKEN=exx-verify-token
META_WHATSAPP_APP_SECRET=

# Fila (opcional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Braspress — cotação de frete (Basic Auth fornecido pela Braspress)
BRASPRESS_USER=
BRASPRESS_PASSWORD=
# Dados do remetente (já têm default no código; sobrescreva só se mudar)
BRASPRESS_CNPJ_REMETENTE=51579683000114
BRASPRESS_CEP_ORIGEM=88352501

# Arlete Transportes (plataforma SSW) — cotação e rastreio
SSW_LOGIN=
SSW_SENHA=
SSW_DOMINIO=ARL
# Dados do remetente/pagador do frete (default no código; sobrescreva se mudar)
SSW_CNPJ_PAGADOR=51579683000114
SSW_CEP_ORIGEM=88352501

# JadLog — cotação (e rastreio). Token JWT fornecido pela JadLog.
JADLOG_TOKEN=
# Defaults no código (sobrescreva só se mudar):
JADLOG_CONTA=123966
JADLOG_CNPJ=51579683000114
JADLOG_MODALIDADE=3
JADLOG_CEP_ORIGEM=88352501
JADLOG_PONTO_EMISSOR=0890
# JADLOG_CONTRATO= (preencher só se a JadLog fornecer)

# App
APP_URL=http://localhost:3000
CRON_SECRET=

# Modo de dados: "memory" (default, simulação) ou "supabase" (auto quando há credenciais)
DATA_DRIVER=memory

# Estoque (planilha "BALANCO ESTOQUE" no Google Drive)
# A planilha precisa estar compartilhada como "Qualquer pessoa com o link pode ver".
# Defaults já apontam para a planilha atual; sobrescreva só se trocar de planilha/abas.
ESTOQUE_SHEET_ID=1Q3PaZbBrCmq_MeXGdnnIOVf3JmwJXrqpAUx92qNWNto
ESTOQUE_TAB_MATERIA=matéria prima
ESTOQUE_TAB_PRODUTO=produto acabado
